/* 通用容器样式 */
.container {
  padding: 40rpx 30rpx;
  background: #0f172a; /* 深色背景让彩色卡片更突出 */
  min-height: 100vh;
}

.header {
  text-align: left;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #f8fafc;
  letter-spacing: -1rpx;
  display: block;
}

.status-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 16rpx;
  font-weight: 500;
}

.countdown-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.countdown-card {
  height: 320rpx;
  border-radius: 50rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20rpx 50rpx rgba(0, 0, 0, 0.3);
  transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
}

.countdown-card:active {
  transform: scale(0.97) translateY(10rpx);
}

/* 卡片内的装饰性大 Emoji 背景 */
.card-bg-emoji {
  position: absolute;
  right: -40rpx;
  bottom: -40rpx;
  font-size: 280rpx;
  opacity: 0.15;
  transform: rotate(-15deg);
  z-index: 1;
}

/* 玻璃感覆盖层 */
.glass-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(110deg, rgba(255, 255, 255, 0.1) 0%, transparent 60%);
  z-index: 2;
}

.card-content {
  position: relative;
  z-index: 3;
  height: 100%;
  padding: 45rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-sizing: border-box;
}

.festival-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.festival-info-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.festival-name {
  font-size: 48rpx;
  font-weight: 900;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.festival-date-tag {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 600;
  background: rgba(0, 0, 0, 0.2);
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  align-self: flex-start;
}

.days-badge {
  background: #ffffff;
  padding: 20rpx 30rpx;
  border-radius: 35rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.2);
}

.days-number {
  font-size: 44rpx;
  font-weight: 900;
  color: #1e293b;
  line-height: 1;
}

.days-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
  margin-top: 4rpx;
  text-transform: uppercase;
}

.festival-bottom {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.festival-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  max-width: 80%;
}

.progress-container {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 10rpx;
  width: 100%;
  overflow: hidden;
  margin-top: 10rpx;
}

.progress-bar {
  height: 100%;
  background: #ffffff;
  border-radius: 10rpx;
  box-shadow: 0 0 15rpx rgba(255, 255, 255, 0.5);
}

/* 进场动画 */
@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-50rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.countdown-card {
  animation: slideIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
}
