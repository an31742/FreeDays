/* 页面容器 */
.container {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 20%, #f8fafc 20%, #f1f5f9 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.95;
  z-index: 0;
}

/* 月度统计卡片 - 强化渐变和光感 */
.stats-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.1) 100%);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  margin: 20rpx 30rpx;
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  color: white;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  position: relative;
  overflow: hidden;
  z-index: 1;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.stats-card.dimmed {
  transform: scale(0.95);
  opacity: 0.7;
  filter: blur(4rpx);
}

.btn-hover {
  opacity: 0.7;
  transform: scale(0.95);
}

.card-hover {
  background: rgba(255, 255, 255, 0.3) !important;
}

.stats-card:active {
  transform: scale(0.98);
  transition: transform 0.2s;
}

.query-btn:active {
  background: rgba(255, 255, 255, 0.4);
}

.stats-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.stats-title {
  font-size: 42rpx;
  font-weight: 800;
  text-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
}

.query-btn {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.query-text {
  font-size: 26rpx;
  font-weight: 600;
}

.stats-content {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.stats-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.15);
  padding: 24rpx 10rpx;
  border-radius: 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.stats-label {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 12rpx;
}

.stats-amount {
  font-size: 34rpx;
  font-weight: 700;
  display: block;
}

/* 快速记账部分 - 移除纯白背景 */
.quick-add-section {
  background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 45rpx rgba(102, 126, 234, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.section-header {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2d3748;
  position: relative;
  padding-left: 24rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: #667eea;
  border-radius: 4rpx;
}

/* 标签页优化 */
.tab-bar {
  display: flex;
  background: #edf2f7;
  padding: 8rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #718096;
  transition: all 0.3s;
  border-radius: 18rpx;
}

.tab-item.active {
  background: white;
  color: #667eea;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.15);
}

/* 分类图标优化 */
.categories-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  margin: 0 -10rpx;
}

.category-section {
  display: flex;
  flex-wrap: wrap;
  width: 100%;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  box-sizing: border-box;
  padding: 0 10rpx;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 10rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s;
}

.category-item:active .category-icon {
  transform: scale(0.9) translateY(4rpx);
}

.icon-emoji {
  font-size: 50rpx;
}

.category-name {
  font-size: 26rpx;
  color: #4a5568;
  font-weight: 500;
}

/* 最近交易列表优化 */
.recent-section {
  background: white;
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 45rpx rgba(0, 0, 0, 0.05);
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f7fafc;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-category {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.category-icon-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.05);
}

.transaction-info {
  display: flex;
  flex-direction: column;
}

.transaction-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3748;
  margin-bottom: 6rpx;
}

.transaction-time {
  font-size: 22rpx;
  color: #a0aec0;
}

.transaction-amount {
  font-size: 32rpx;
  font-weight: 800;
}

.transaction-amount.expense {
  color: #e53e3e;
}

.transaction-amount.income {
  color: #38a169;
}

/* 悬浮按钮优化 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 110rpx;
  height: 110rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 15rpx 35rpx rgba(118, 75, 162, 0.4);
  z-index: 99;
}

.fab-icon {
  color: white;
  font-size: 60rpx;
  font-weight: 300;
}

/* 查询面板美化 */
.query-panel {
  background: rgba(255, 255, 255, 0.98);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.2);
  border: 1rpx solid #edf2f7;
  position: relative;
  z-index: 10;
}

.query-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2d3748;
  display: block;
  text-align: center;
  margin-bottom: 40rpx;
}

.query-mode-tabs {
  display: flex;
  background: #f7fafc;
  padding: 6rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
}

.query-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #718096;
  border-radius: 16rpx;
}

.query-tab.active {
  background: white;
  color: #667eea;
  font-weight: 700;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.05);
}

.picker-item {
  background: #f8fafc;
  padding: 30rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-label {
  font-size: 28rpx;
  color: #4a5568;
}

.picker-value {
  font-size: 30rpx;
  color: #667eea;
  font-weight: 700;
}

.query-btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;
  color: white !important;
  border-radius: 24rpx !important;
  font-weight: 700 !important;
  margin-bottom: 20rpx !important;
}

.query-btn-cancel {
  background: #f7fafc !important;
  color: #718096 !important;
  border-radius: 24rpx !important;
  font-weight: 600 !important;
}
