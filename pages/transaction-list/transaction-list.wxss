.container {
  background: #f8fafc;
  min-height: 100vh;
  padding-bottom: 60rpx;
  position: relative;
}

.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 450rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  z-index: 0;
}

/* 账单头部卡片 */
.bill-header {
  position: relative;
  z-index: 1;
  padding: 40rpx 30rpx;
  color: white;
}

.date-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 50rpx;
}

.current-date {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
}

.arrow-down {
  font-size: 20rpx;
}

.mode-switch {
  display: flex;
  background: rgba(0, 0, 0, 0.1);
  padding: 6rpx;
  border-radius: 20rpx;
}

.mode-btn {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.mode-btn.active {
  background: white;
  color: #667eea;
  font-weight: 700;
}

.total-stats {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(20rpx);
  padding: 40rpx;
  border-radius: 35rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.8;
  margin-bottom: 12rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 800;
}

.stat-value.expense { color: #ff6b6b; }
.stat-value.income { color: #2ecc71; }
.stat-value.balance { color: #ffffff; }

/* 柱状图部分 */
.chart-section {
  margin: 30rpx;
  background: white;
  border-radius: 35rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #667eea;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 220rpx;
  padding: 20rpx 0;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
  margin-right: 20rpx;
}

.bar-group {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 150rpx;
}

.bar {
  width: 16rpx;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.6s ease;
}

.bar.income { background: #2ecc71; }
.bar.expense { background: #ff6b6b; }

.bar-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 16rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-top: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #64748b;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.dot.income { background: #2ecc71; }
.dot.expense { background: #ff6b6b; }

/* 排行榜部分 */
.rank-section {
  margin: 30rpx;
  background: white;
  border-radius: 35rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.rank-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rank-info {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.rank-name {
  flex: 1;
  color: #334155;
  font-weight: 600;
}

.rank-percent {
  color: #94a3b8;
  margin-right: 20rpx;
  font-size: 24rpx;
}

.rank-amount {
  color: #1e293b;
  font-weight: 700;
}

.progress-bg {
  height: 12rpx;
  background: #f1f5f9;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.8s ease;
}

/* 明细列表 */
.detail-section {
  margin: 30rpx;
  background: white;
  border-radius: 35rpx;
  padding: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.05);
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.transaction-item:last-child {
  border-bottom: none;
}

.item-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
}

.item-date {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.item-amount {
  font-size: 30rpx;
  font-weight: 800;
}

.item-amount.income { color: #2ecc71; }
.item-amount.expense { color: #ff6b6b; }

.load-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #94a3b8;
}

.empty-state {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}
