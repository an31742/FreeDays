/* pages/query-result/query-result.wxss */
.container {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 20%, #f8fafc 20%, #f1f5f9 100%);
  min-height: 100vh;
  padding-bottom: 40rpx;
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 300rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.95;
  z-index: 0;
}

/* 查询结果头部 */
.result-header {
  padding: 60rpx 30rpx;
  position: relative;
  z-index: 1;
}

.header-content {
  text-align: center;
  color: white;
}

.result-title {
  font-size: 48rpx;
  font-weight: 800;
  display: block;
  margin-bottom: 24rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 2rpx;
}

.result-summary {
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  display: inline-block;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.summary-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}

/* 统计卡片 - 玻璃拟态 */
.stats-section {
  padding: 0 30rpx;
  position: relative;
  z-index: 1;
}

.stats-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(255, 255, 255, 0.8) 100%);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 20rpx 50rpx rgba(102, 126, 234, 0.15);
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.stats-item {
  text-align: center;
  flex: 1;
  padding: 30rpx 15rpx;
  border-radius: 28rpx;
  transition: transform 0.3s;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
}

.stats-item:active {
  transform: scale(0.95);
}

.stats-item.income {
  background: linear-gradient(135deg, rgba(56, 161, 105, 0.08), rgba(56, 161, 105, 0.03));
  border: 2rpx solid rgba(56, 161, 105, 0.1);
}

.stats-item.expense {
  background: linear-gradient(135deg, rgba(229, 62, 62, 0.08), rgba(229, 62, 62, 0.03));
  border: 2rpx solid rgba(229, 62, 62, 0.1);
}

.stats-item.balance {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.08), rgba(118, 75, 162, 0.08));
  border: 2rpx solid rgba(102, 126, 234, 0.1);
}

.stats-label {
  display: block;
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.stats-amount {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: #2d3748;
}

.stats-amount.positive {
  color: #38a169;
}

.stats-amount.negative {
  color: #e53e3e;
}

/* 图表展示 - 渐变背景 */
.chart-section {
  margin: 40rpx 30rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f8faff 100%);
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.chart-header {
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
}

.chart-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2d3748;
  padding-left: 20rpx;
  border-left: 8rpx solid #667eea;
}

/* 分类图表项美化 */
.chart-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.chart-item:last-child {
  border-bottom: none;
}

.chart-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.1);
}

.chart-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a5568;
}

.chart-bar {
  height: 20rpx;
  background: #edf2f7;
  border-radius: 10rpx;
  margin: 0 20rpx;
}

.chart-bar-fill {
  border-radius: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.chart-amount {
  font-size: 32rpx;
  font-weight: 800;
  color: #2d3748;
}

/* 列表展示美化 */
.list-section {
  margin: 40rpx 30rpx;
  background: white;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f7fafc;
}

.transaction-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.category-icon-small {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.transaction-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3748;
  margin-bottom: 8rpx;
}

.transaction-time {
  font-size: 24rpx;
  color: #a0aec0;
}

.transaction-amount {
  font-size: 34rpx;
  font-weight: 800;
}

/* 空状态美化 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  display: block;
}

.empty-text {
  font-size: 32rpx;
  color: #718096;
  font-weight: 600;
}
