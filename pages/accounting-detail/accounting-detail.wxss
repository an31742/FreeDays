/* 页面容器 */
.container {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 25%, #f8fafc 25%, #f1f5f9 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.95;
  z-index: 0;
}

/* 收支类型切换 - 强化视觉反馈 */
.type-selector {
  display: flex;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 10rpx;
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.type-item.active {
  color: white;
  transform: scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.type-item.active.expense {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
}

.type-item.active.income {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
}

.tab-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 金额输入区域 - 强化质感 */
.amount-section {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 80rpx 40rpx;
  box-shadow: 0 25rpx 60rpx rgba(0, 0, 0, 0.08);
  text-align: center;
  position: relative;
  z-index: 1;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 32rpx;
  padding: 40rpx;
  border: 3rpx solid #edf2f7;
  transition: border-color 0.3s;
}

.amount-input-wrapper:focus-within {
  border-color: #667eea;
}

.currency-symbol {
  font-size: 80rpx;
  font-weight: 800;
  color: #2d3748;
  margin-right: 15rpx;
}

.amount-input {
  font-size: 80rpx;
  font-weight: 800;
  color: #1a202c;
  height: 100rpx;
  text-align: left;
}

/* 分类选择美化 */
.category-section {
  background: white;
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 45rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2d3748;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #667eea;
  border-radius: 4rpx;
}

.categories-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  margin: 0 -10rpx;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 10rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
  box-sizing: border-box;
}

.category-item.selected {
  background: #f0f4ff;
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.15);
}

.category-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 30rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.06);
}

.category-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a5568;
}

/* 备注和日期输入美化 */
.input-section {
  background: white;
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
}

.input-group {
  margin-bottom: 30rpx;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #718096;
  margin-bottom: 20rpx;
  display: block;
}

.text-input, .picker-value {
  background: #f8fafc;
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #2d3748;
  border: 2rpx solid #edf2f7;
}

/* 按钮美化 */
.action-section {
  padding: 40rpx 30rpx;
}

.save-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
  transition: all 0.2s;
}

.category-item:active {
  transform: scale(0.9);
  background: #f0f4ff;
}

.delete-btn {
  background: #fff !important;
  color: #ff4757 !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  margin-top: 30rpx !important;
  border: 2rpx solid #ff4757 !important;
  border-radius: 30rpx !important;
}
