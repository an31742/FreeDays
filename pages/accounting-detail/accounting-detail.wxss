/* 页面容器 */
.container {
  background: linear-gradient(180deg, #667eea 0%, #764ba2 25%, #f8fafc 25%, #f1f5f9 100%);
  min-height: 100vh;
  padding-bottom: 120rpx;
  position: relative;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  opacity: 0.95;
  z-index: 0;
}

/* 收支类型切换 - 强化视觉反馈 */
.type-selector {
  display: flex;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 10rpx;
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.15);
  position: relative;
  z-index: 1;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.7);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.type-item.active {
  color: white;
  transform: scale(1.05);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.type-item.active.expense {
  background: linear-gradient(135deg, #ff6b6b, #ff4757);
}

.type-item.active.income {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
}

.tab-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

/* 金额输入区域 - 强化质感 */
.amount-section {
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 80rpx 40rpx;
  box-shadow: 0 25rpx 60rpx rgba(0, 0, 0, 0.08);
  text-align: center;
  position: relative;
  z-index: 1;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
  border-radius: 32rpx;
  padding: 40rpx;
  border: 3rpx solid #edf2f7;
  transition: border-color 0.3s;
}

.amount-input-wrapper:focus-within {
  border-color: #667eea;
}

.currency-symbol {
  font-size: 80rpx;
  font-weight: 800;
  color: #2d3748;
  margin-right: 15rpx;
}

.amount-input {
  font-size: 80rpx;
  font-weight: 800;
  color: #1a202c;
  height: 100rpx;
  text-align: left;
}

/* 分类选择美化 */
.category-section {
  background: white;
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 45rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #2d3748;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: #667eea;
  border-radius: 4rpx;
}

.categories-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  margin: 0 -10rpx;
}

.category-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 10rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  transition: all 0.3s;
  box-sizing: border-box;
}

.category-item.selected {
  background: #f0f4ff;
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.15);
}

.category-icon {
  width: 90rpx;
  height: 90rpx;
  border-radius: 30rpx;
  margin-bottom: 15rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 6rpx 15rpx rgba(0, 0, 0, 0.06);
}

.category-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #4a5568;
}

/* 日期/备注表单区域 */
.form-section {
  background: white;
  margin: 30rpx;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 15rpx 40rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8fafc;
  border-radius: 24rpx;
  padding: 30rpx;
  border: 2rpx solid #edf2f7;
  transition: border-color 0.3s;
}

.form-item:active {
  border-color: #667eea;
}

.form-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #2d3748;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.form-value {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  color: #667eea;
  font-weight: 600;
}

.arrow {
  font-size: 28rpx;
  color: #a0aec0;
  font-weight: 300;
}

.form-input {
  flex: 1;
  text-align: right;
  font-size: 30rpx;
  color: #2d3748;
  background: transparent;
  padding: 0;
}

.form-input::placeholder {
  color: #cbd5e0;
}

.form-divider {
  height: 1rpx;
  background: #edf2f7;
  margin: 8rpx 0;
}

.date-readonly {
  border-color: transparent;
  background: transparent;
}

.form-value-readonly {
  font-size: 30rpx;
  color: #4a5568;
  font-weight: 500;
}

/* 操作按钮组 */
.action-buttons {
  padding: 20rpx 30rpx 60rpx;
}

.save-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: white;
  letter-spacing: 8rpx;
  border: none;
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.save-btn.expense {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4757 100%);
}

.save-btn.income {
  background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%);
}

.save-btn:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.edit-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  border-radius: 50rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #667eea;
  letter-spacing: 8rpx;
  background: white;
  border: 3rpx solid #667eea;
  box-shadow: 0 10rpx 25rpx rgba(102, 126, 234, 0.12);
  transition: all 0.3s;
}

.edit-btn:active {
  transform: scale(0.96);
  background: #f0f4ff;
}

.delete-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #ff4757;
  letter-spacing: 4rpx;
  background: white;
  border: 2rpx solid #ff4757;
  margin-top: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 71, 87, 0.08);
  transition: all 0.3s;
}

.delete-btn:active {
  transform: scale(0.96);
  background: #fff5f5;
}

.category-item:active {
  transform: scale(0.9);
  background: #f0f4ff;
}
